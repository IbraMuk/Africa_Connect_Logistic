# Configuration du serveur
NODE_ENV=development
PORT=5000

# Configuration de la base de données PostgreSQL
# Option 1 : URL complète (Supabase / Render / Railway)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Option 2 : paramètres individuels (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=africa_connect_logistic
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_SSL=false

# Clé secrète pour JWT
JWT_SECRET=votre_clé_secrète_jwt_très_longue_et_sécurisée
JWT_EXPIRE=7d

# Configuration de l'email (optionnel)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASS=votre_mot_de_passe_app
